# ik-fiesta-sample-webapp — Windows (Server Core) image (multi-stage; builds from source).
FROM mcr.microsoft.com/dotnet/sdk:10.0-windowsservercore-ltsc2022 AS build
WORKDIR /src
COPY . .
RUN dotnet publish src/Fiesta.Webapp/Fiesta.Webapp.csproj -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:10.0-windowsservercore-ltsc2022
WORKDIR /app
COPY --from=build /app .
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080
ENTRYPOINT ["dotnet", "Fiesta.Webapp.dll"]
